# Toggle preview-only mode (no Supabase needed — uses mock data).
# Set to "false" once Supabase env vars below are filled in.
NEXT_PUBLIC_USE_MOCK=true

# Supabase project — copy from Supabase Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Bettina's admin email (any account with this email gets is_admin via the
# is_admin column in profiles; this var is only a fallback default).
NEXT_PUBLIC_ADMIN_EMAIL=baranyibettina@entropybreakers.com

# WhatsApp number for the support CTA (with country code, digits only).
NEXT_PUBLIC_SUPPORT_WHATSAPP=

# Landing page URL — used in "no account yet?" links.
NEXT_PUBLIC_LANDING_URL=https://getclientready.entropybreakers.com

# Anthropic Claude API key for AI feedback drafts on /admin/submissions/[id].
# SERVER-ONLY — must NOT have NEXT_PUBLIC_ prefix (would leak to client bundle).
# Without this, the "AI draft" button in the feedback editor errors at runtime.
# Set in Vercel → Settings → Environment Variables → Production only.
ANTHROPIC_API_KEY=

# OpenAI API key — used ONLY to transcribe audio submissions (Whisper) so the
# "AI draft" button works on spoken exercises. Get one at
# https://platform.openai.com/api-keys
# SERVER-ONLY. Without this, audio submissions can still be reviewed manually;
# the AI draft button just reports that no transcript is available.
OPENAI_API_KEY=

# Resend API key for transactional email (feedback ready notifications,
# welcome emails). Get one at https://resend.com/api-keys
# SERVER-ONLY. Without this, emails are silently skipped (Save Feedback
# still works — just no notification).
RESEND_API_KEY=

# Sender address for transactional email. Must be on a domain verified
# in Resend (https://resend.com/domains).
EMAIL_FROM="Bettina @ Get Client Ready <bettina@entropybreakers.com>"

# Plausible Analytics — cookieless, EU-hosted (Estonia). Optional.
# When unset, no analytics script is loaded (zero third-party requests).
# To activate: register the platform domain at https://plausible.io/sites
# and set this var to the same value (e.g. "app.entropybreakers.com").
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Supabase service-role key — bypasses Row-Level Security.
# Required ONLY for the Stripe webhook (auto user provisioning).
# Find in Supabase Dashboard → Project Settings → API → service_role.
# SERVER-ONLY — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — server-only credentials for the /api/stripe/webhook endpoint.
# Required for automated user creation after Payment Link checkout.
# STRIPE_SECRET_KEY:    Stripe Dashboard → Developers → API keys → "sk_live_..."
# STRIPE_WEBHOOK_SECRET: Stripe Dashboard → Developers → Webhooks → endpoint
#                       → "Signing secret" (starts with "whsec_...")
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Map Stripe Price IDs → internal tier. Get each from Stripe Dashboard →
# Products → click product → Pricing section → "price_..." (NOT the
# product id starting with "prod_").
STRIPE_PRICE_SPRINT=
STRIPE_PRICE_SHIFT=
STRIPE_PRICE_REFRAME=
