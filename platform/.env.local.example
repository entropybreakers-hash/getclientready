# Toggle preview-only mode (no Supabase needed — uses mock data).
# Set to "false" once Supabase env vars below are filled in.
NEXT_PUBLIC_USE_MOCK=true

# Supabase project — copy from Supabase Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Bettina's admin email (any account with this email gets is_admin via the
# is_admin column in profiles; this var is only a fallback default).
NEXT_PUBLIC_ADMIN_EMAIL=baranyibettina@entropybreakers.com

# WhatsApp number for the support CTA (with country code, digits only).
NEXT_PUBLIC_SUPPORT_WHATSAPP=

# Landing page URL — used in "no account yet?" links.
NEXT_PUBLIC_LANDING_URL=https://getclientready.entropybreakers.com

# Anthropic Claude API key for AI feedback drafts on /admin/submissions/[id].
# SERVER-ONLY — must NOT have NEXT_PUBLIC_ prefix (would leak to client bundle).
# Without this, the "AI draft" button in the feedback editor errors at runtime.
# Set in Vercel → Settings → Environment Variables → Production only.
ANTHROPIC_API_KEY=
